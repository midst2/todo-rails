<div class="w-full flex  justify-between p-4 flex-row">
  <div class="flex items-center gap-2">
    <%= link_to "Todo", root_path, class: "text-4xl font-bold" %>
    <%= image_tag "check.png", class: "w-10 h-10" %>
  </div>

  <% if user_signed_in? %>
    <%= link_to "Logout",
  destroy_user_session_path,
  data: { turbo_method: :delete },
  class: "bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg" %>
  <% else %>
  <div class='flex gap-2'>
    <%= link_to "Login", new_user_session_path, class: "bg-green-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg" %>
    <%= link_to "Sign Up", new_user_registration_path, class: "bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg" %>
  </div>
  <% end %>
</div>
<hr class="border-t border-gray-300">