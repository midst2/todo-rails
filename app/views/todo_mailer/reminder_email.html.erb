<!DOCTYPE html>
<html>
  <head>
    <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
    <style>
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        line-height: 1.6;
        color: #1a1a1a;
        margin: 0;
        padding: 0;
        background-color: #f8fafc;
      }
      .container {
        max-width: 600px;
        margin: 40px auto;
        padding: 40px;
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
      }
      .header {
        margin-bottom: 30px;
        text-align: center;
      }
      h1 {
        font-size: 24px;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
      }
      .todo-card {
        padding: 24px;
        background: #f1f5f9;
        border-radius: 8px;
        margin: 24px 0;
        border-left: 4px solid #3b82f6;
      }
      .todo-content {
        font-size: 18px;
        font-weight: 500;
        color: #1e293b;
      }
      .todo-meta {
        margin-top: 12px;
        font-size: 14px;
        color: #64748b;
      }
      .footer {
        margin-top: 40px;
        text-align: center;
        font-size: 14px;
        color: #94a3b8;
      }
      .btn {
        display: inline-block;
        padding: 12px 24px;
        background-color: #3b82f6;
        color: #ffffff;
        text-decoration: none;
        border-radius: 6px;
        font-weight: 600;
        margin-top: 20px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>Todo Reminder</h1>
      </div>
      
      <p>Hi <%= @user.email %>,</p>
      
      <p>This is a reminder that the following task is due tomorrow:</p>
      
      <div class="todo-card">
        <div class="todo-content"><%= @todo.content %></div>
        <div class="todo-meta">
          <strong>Due Date:</strong> <%= @todo.due_date.strftime("%B %d, %Y") %><br>
          <strong>Folder:</strong> <%= @todo.folder %> | 
          <strong>Priority:</strong> <%= @todo.priority %>
        </div>
      </div>
      
      <p>Stay productive!</p>
      
      <div class="footer">
        Sent from your Todo Application
      </div>
    </div>
  </body>
</html>