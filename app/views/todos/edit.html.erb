<% content_for :title, "Edit Task" %>

<div class="w-full max-w-lg p-5">
  <%= link_to todos_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-4" do %>
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back
  <% end %>

  <h1 class="font-bold text-2xl mb-1">Edit Task</h1>

  <% if @todo.reminder_sent? %>
    <div class="flex items-center gap-2 bg-neutral-100 rounded-lg px-3 py-2 mb-4 text-sm text-gray-600">
      <svg class="w-4 h-4 shrink-0" fill="rgb(30, 48, 80)" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
      </svg>
      Reminder already sent — update "Remind Me At" to trigger a new one.
    </div>
  <% end %>

  <div class="mb-5"></div>

  <%= render "form", todo: @todo %>
</div>
