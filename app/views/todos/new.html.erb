<% content_for :title, "New Task" %>

<div class="w-full max-w-lg p-5">
  <%= link_to todos_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-4" do %>
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back
  <% end %>

  <h1 class="font-bold text-2xl mb-5">New Task</h1>

  <%= render "form", todo: @todo %>
</div>
